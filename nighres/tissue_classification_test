import nighres
import os

input_image = "/data/safe/din_testfil.nii"

output_dir = "/data/safe"

nighres.backend.init_Engine()


mgdm = nighres.brain.mgdm_segmentation(
    contrast_image1=input_image,
    contrast_type1="MP2RAGE-INV2", # Ändra till din kontrasttyp om du inte kör MP2RAGE (t.ex. "T1w")
    save_data=True,
    file_name="test_segmentation",
    output_dir=output_dir
)

print("Done! 🧠")
